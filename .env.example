APP_ENV=dev
AUTH_MODE=jwt

# Required when APP_ENV is not dev (must be >= 32 chars)
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars
MASTER_KEY=replace-with-a-strong-random-secret-at-least-32-chars
# SHADOW_MASTER_KEY=replace-with-a-strong-random-secret-at-least-32-chars

# Required when APP_ENV is not dev (comma-separated list)
ALLOWED_ORIGINS=https://app.shadowaigateway.com,http://localhost:3000,http://127.0.0.1:3000

# API runtime paths (inside container)
DB_PATH=/data/app.db
LOG_DIR=/data/logs
MIGRATIONS_DIR=/app/migrations

# Product app API URL (compose overrides to http://api:8080 for container-to-container traffic)
API_BASE_URL=http://127.0.0.1:8080
APP_BASE_URL=http://localhost:8501

# Optional provider settings
GEMINI_API_KEY=
GEMINI_MODEL=models/gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
TAVILY_API_KEY=

# Optional platform settings
AUDIT_SIGNING_KEY=dev-audit-key-change-me
RESTORE_REDACTED_VALUES=true
ENTERPRISE_MODE=true
ENFORCE_RBAC=true
ENABLE_TENANT_LIMITS=true
TENANT_RPM_DEFAULT=60
TENANT_RPD_DEFAULT=2000
TENANT_MAX_TOKENS_DEFAULT=200000
ENABLE_JOB_WORKER=true
